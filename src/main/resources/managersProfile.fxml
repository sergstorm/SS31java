<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo.Controllers.BossController"
            prefHeight="400.0" prefWidth="600.0">



    <?import javafx.geometry.Insets?>
    <?import javafx.scene.control.Button?>
    <?import javafx.scene.control.Label?>
    <?import javafx.scene.control.TableColumn?>
    <?import javafx.scene.control.TableView?>
    <?import javafx.scene.layout.HBox?>
    <?import javafx.scene.layout.Pane?>
    <?import javafx.scene.layout.VBox?>
    <?import javafx.scene.text.Font?>

    <HBox prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #F5F7FA;" xmlns="http://javafx.com" xmlns:fx="http://javafx.com">
        <children>

            <!-- LEFT SIDEBAR: MANAGER PROFILE CARD CONTAINER (Width: 350px) -->
            <VBox prefHeight="800.0" prefWidth="350.0" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 5, 0);">
                <children>
                    <!-- Header Banner Graphic Area (Matching your original purple scheme) -->
                    <VBox alignment="CENTER" prefHeight="220.0" prefWidth="350.0" style="-fx-background-color: #8E24AA;">
                        <children>
                            <!-- Circular Avatar Base -->
                            <VBox alignment="CENTER" prefHeight="110.0" prefWidth="110.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 1000;">
                                <children>
                                    <Label text="👤" textFill="#8E24AA">
                                        <font>
                                            <Font size="52.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <!-- Manager Details (Datos Section) -->
                    <VBox alignment="TOP_CENTER" spacing="15.0" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="30.0" left="25.0" right="25.0" top="25.0" />
                        </padding>
                        <children>
                            <Label text="Jane Smith" textFill="#212121">
                                <font>
                                    <Font name="System Bold" size="26.0" />
                                </font>
                            </Label>

                            <Label style="-fx-background-color: #F3E5F5; -fx-background-radius: 15; -fx-padding: 4 15 4 15;" text="DEPARTMENT MANAGER" textFill="#8E24AA">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>

                            <!-- Metadata Details Grid -->
                            <VBox spacing="10.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-padding: 15;">
                                <children>
                                    <HBox>
                                        <children>
                                            <Label text="Email:" textFill="#757575" prefWidth="85.0" />
                                            <Label text="jane.smith@company.com" textFill="#212121" wrapText="true" />
                                        </children>
                                    </HBox>
                                    <HBox>
                                        <children>
                                            <Label text="Department:" textFill="#757575" prefWidth="85.0" />
                                            <Label text="UI/UX &amp; Development" textFill="#212121" />
                                        </children>
                                    </HBox>
                                    <HBox>
                                        <children>
                                            <Label text="Office Room:" textFill="#757575" prefWidth="85.0" />
                                            <Label text="Suite 404-B" textFill="#212121" />
                                        </children>
                                    </HBox>
                                    <HBox>
                                        <children>
                                            <Label text="Team Count:" textFill="#757575" prefWidth="85.0" />
                                            <Label text="14 Active Workers" textFill="#8E24AA" style="-fx-font-weight: bold;" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>

                            <Pane VBox.vgrow="ALWAYS" />

                            <!-- Action buttons -->
                            <Button fx:id="backToLanding" onAction="#logout"
                                    prefHeight="40.0" prefWidth="300.0"
                                    style="-fx-background-color: transparent; -fx-border-color: #BDBDBD; -fx-border-radius: 6; -fx-text-fill: #757575; -fx-font-weight: bold;"
                                    text="SIGN OUT"
                            />
                            <Button fx:id="backToLanding2" onAction="#goBackToLandingPageManagers"
                                    prefHeight="40.0" prefWidth="300.0"
                                    style="-fx-background-color: transparent; -fx-border-color: #BDBDBD; -fx-border-radius: 6; -fx-text-fill: #757575; -fx-font-weight: bold;"
                                    text="BackToLanding"
                            />
                        </children>
                    </VBox>
                </children>
            </VBox>

            <!-- RIGHT CONTENT AREA: TEAM ROSTER & OPERATIONS (Width: 850px) -->
            <VBox prefHeight="800.0" prefWidth="850.0" spacing="25.0" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30.0" left="35.0" right="35.0" top="35.0" />
                </padding>
                <children>

                    <!-- TOP VIEW TITLE -->
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <VBox>
                                <children>
                                    <Label text="Departmental Roster &amp; Operational Progress" textFill="#1A1D20">
                                        <font>
                                            <Font name="System Bold" size="28.0" />
                                        </font>
                                    </Label>
                                    <Label text="Track your managed direct reports, their core tasks, and operational availability." textFill="#8A92A6" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- COUNTER STATS CARDS ROW -->
                    <HBox spacing="20.0" prefHeight="100.0">
                        <children>
                            <!-- Stat Card 1 -->
                            <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                                <children>
                                    <Label text="Managed Workers" textFill="#8A92A6" style="-fx-font-size: 13;" />
                                    <Label text="14 Team Members" textFill="#212121">
                                        <font>
                                            <Font name="System Bold" size="24.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                            <!-- Stat Card 2 -->
                            <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                                <children>
                                    <Label text="Total Department Tasks" textFill="#8A92A6" style="-fx-font-size: 13;" />
                                    <Label text="118 Total" textFill="#8E24AA">
                                        <font>
                                            <Font name="System Bold" size="24.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                            <!-- Stat Card 3 -->
                            <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                                <children>
                                    <Label text="Critical Blockers Pending" textFill="#8A92A6" style="-fx-font-size: 13;" />
                                    <Label text="3 Blocked" textFill="#D32F2F">
                                        <font>
                                            <Font name="System Bold" size="24.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- DATALIST / TEAM TABLE CONTAINER -->
                    <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 8, 0, 0, 4);">
                        <children>
                            <Label text="Direct Reports Performance Tracking Directory" textFill="#212121">
                                <font>
                                    <Font name="System Bold" size="16.0" />
                                </font>
                            </Label>

                            <!-- Main TableView Component to show Workers and their Task Summary -->
                            <TableView fx:id="workersTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                                <columns>
                                    <TableColumn fx:id="colWorkerId" prefWidth="90.0" text="Worker ID" />
                                    <TableColumn fx:id="colWorkerName" prefWidth="200.0" text="Employee Name" />
                                    <TableColumn fx:id="colRole" prefWidth="160.0" text="Role/Title" />
                                    <TableColumn fx:id="colActiveTask" prefWidth="260.0" text="Current Primary Task" />
                                    <TableColumn fx:id="colTaskCount" prefWidth="120.0" text="Pending Count" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </children>
                    </VBox>

                </children>
            </VBox>

        </children>
    </HBox>


</AnchorPane>
