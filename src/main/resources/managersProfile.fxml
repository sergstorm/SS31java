<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<!-- skill: dynamic-map (not needed), skill: local (not needed) -->
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com" xmlns:fx="http://fxml.com" fx:controller="com.example.demo.Controllers.ManagerController">
    <children>
        <HBox prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #F5F7FA;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- LEFT SIDEBAR: MANAGER PROFILE CARD CONTAINER (Width: 350px) -->
                <VBox prefHeight="800.0" prefWidth="350.0" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 5, 0);">
                    <children>
                        <!-- Header Banner Graphic Area -->
                        <VBox alignment="CENTER" prefHeight="220.0" prefWidth="350.0" style="-fx-background-color: #8E24AA;">
                            <children>
                                <!-- Circular Avatar Base -->
                                <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="110.0" prefWidth="110.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 1000;">
                                    <children>
                                        <Label text="👤" textFill="#8E24AA">
                                            <font>
                                                <Font size="52.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Manager Details (Datos Section) -->
                        <VBox alignment="TOP_CENTER" spacing="15.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="30.0" left="25.0" right="25.0" top="25.0" />
                            </padding>
                            <children>
                                <Label text="Managers Name" textFill="#212121">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Label>

                                <Label style="-fx-background-color: #F3E5F5; -fx-background-radius: 15; -fx-padding: 4 15 4 15;" text="DEPARTMENT MANAGER" textFill="#8E24AA">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>

                                <!-- Metadata Details Grid -->
                                <VBox fx:id="panelDetallesManager" spacing="10.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-padding: 15;">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Detalles del Mánager" textFill="#212121" />

                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label prefWidth="100.0" text="Manager ID:" textFill="#757575" />
                                                <TextField fx:id="txtManagerId" editable="false" prefWidth="150.0" style="-fx-background-color: #E2E8F0;" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label prefWidth="100.0" text="Department:" textFill="#757575" />
                                                <TextField fx:id="txtDepartment" prefWidth="150.0" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label prefWidth="100.0" text="Alias:" textFill="#757575" />
                                                <TextField fx:id="txtAlias" prefWidth="150.0" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label prefWidth="100.0" text="Achievement:" textFill="#757575" />
                                                <TextField fx:id="txtAchievement" prefWidth="150.0" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label prefWidth="100.0" text="Aim / Meta:" textFill="#757575" />
                                                <TextField fx:id="txtAim" prefWidth="150.0" />
                                            </children>
                                        </HBox>

                                        <!-- Botones de Acción para Mánagers -->
                                        <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                                            <children>
                                                <Button fx:id="LbB" onAction="#limpiarSeleccionManager" style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-background-radius: 6;" text="Limpiar" />
                                                <Button fx:id="GBB" onAction="#actualizarManager" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" text="Guardar" />
                                                <Button fx:id="EBB" onAction="#eliminarManager" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" text="Eliminar" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Pane VBox.vgrow="ALWAYS" />

                                <!-- Action buttons -->
                                <Button fx:id="backToLanding" onAction="#logout" prefHeight="40.0" prefWidth="300.0" style="-fx-background-color: transparent; -fx-border-color: #BDBDBD; -fx-border-radius: 6; -fx-text-fill: #757575; -fx-font-weight: bold;" text="SIGN OUT" />
                                <Button fx:id="backToLanding2" onAction="#goBackToLandingPageManagers" prefHeight="40.0" prefWidth="300.0" style="-fx-background-color: transparent; -fx-border-color: #BDBDBD; -fx-border-radius: 6; -fx-text-fill: #757575; -fx-font-weight: bold;" text="BackToLanding" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- RIGHT CONTENT AREA: TEAM ROSTER & OPERATIONS (Width: 850px) -->
                <VBox prefHeight="800.0" prefWidth="850.0" spacing="20.0" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="35.0" right="35.0" top="35.0" />
                    </padding>
                    <children>
                        <!-- Top Bar: Title and Add Button -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Label text="Team Roster &amp; Operations" textFill="#212121">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Pane HBox.hgrow="ALWAYS" />
                                <!-- BOTÓN AGREGADO AQUÍ -->
                                <Button fx:id="btnAddMember" onAction="#mostrarFormularioAgregar" prefHeight="38.0"
                                        style="-fx-background-color: #8E24AA; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="➕ Añadir Dept" />
                            </children>
                        </HBox>

                        <!-- Tabla de miembros -->

                        <TableView fx:id="managersTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="managrId" prefWidth="100.0" text="Manager ID" />
                                <TableColumn fx:id="department" prefWidth="200.0" text="Department" />
                                <TableColumn fx:id="alias" prefWidth="150.0" text="Alias" />
                                <TableColumn fx:id="achivment" prefWidth="200.0" text="Achievement" />
                                <TableColumn fx:id="aim" prefWidth="200.0" text="Aim / Meta" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
