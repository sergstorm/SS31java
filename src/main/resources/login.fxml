<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="450.0" prefWidth="380.0" spacing="20.0" style="-fx-background-color: #fef3ef; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.Controllers.RegLoginAuthController">
    <padding>
        <Insets bottom="30.0" left="35.0" right="35.0" top="35.0" />
    </padding>
    <children>
        <!-- Título Principal -->
        <Label text="Bienvenido" textFill="#2c3e50">
            <font>
                <Font name="Segoe UI Bold" size="28.0" />
            </font>
        </Label>

        <!-- Subtítulo o Mensaje de Feedback -->
        <Label fx:id="logLable" text="Inicia sesión para continuar" textAlignment="CENTER" textFill="#7f8c8d" wrapText="true">
            <font>
                <Font name="Segoe UI" size="14.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
      <Label prefHeight="18.0" prefWidth="309.0" text="UserName">
         <font>
            <Font name="Inter Italic" size="24.0" />
         </font>
      </Label>

        <!-- Campo de Usuario -->
        <TextField fx:id="loginUsernameField" prefHeight="40.0" promptText="Usuario" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 14px; -fx-text-fill: #212529;" />
      <Label prefHeight="18.0" prefWidth="305.0" text="Password">
         <font>
            <Font name="Liberation Serif Bold Italic" size="26.0" />
         </font>
      </Label>

        <!-- Campo de Contraseña -->
        <PasswordField fx:id="loginPasswordField" prefHeight="40.0" promptText="Contraseña" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 14px; -fx-text-fill: #212529;" />

        <!-- Botón de Login Principal -->
        <Button mnemonicParsing="false" onAction="#login" prefHeight="42.0" prefWidth="Infinity" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Iniciar Sesión" />

        <!-- Botón de Registro -->
        <Button mnemonicParsing="false" onAction="#switchToView1" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-font-size: 13px; -fx-cursor: hand;" text="¿No tienes cuenta? Regístrate" />
    </children>
</VBox>
