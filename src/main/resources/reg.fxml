<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="520.0" prefWidth="380.0" spacing="18.0"
      style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5);"
      xmlns="http://javafx.com" xmlns:fx="http://fxml.com"
      fx:controller="com.example.demo.Controllers.RegLoginAuthController">
    <padding>
        <Insets bottom="30.0" left="35.0" right="35.0" top="35.0" />
    </padding>
    <children>
        <!-- Título de la Tarjeta -->
        <Label text="Crear Cuenta" textFill="#2c3e50">
            <font>
                <Font name="Segoe UI Bold" size="26.0" />
            </font>
        </Label>

        <!-- Etiqueta de Feedback Dinámico para Errores/Éxito -->
        <Label fx:id="regLable" text="Completa tus datos para registrarte" textFill="#7f8c8d" wrapText="true" textAlignment="CENTER">
            <font>
                <Font name="Segoe UI" size="13.0" />
            </font>
            <VBox.margin>
                <Insets bottom="5.0" />
            </VBox.margin>
        </Label>

        <!-- Campo de Texto: Usuario -->
        <TextField fx:id="regUsername" prefHeight="40.0" promptText="Nombre de usuario"
                   style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 14px; -fx-text-fill: #212529;" />

        <!-- Campo de Texto: Correo Electrónico -->
        <TextField fx:id="regEmail" prefHeight="40.0" promptText="Correo electrónico"
                   style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 14px; -fx-text-fill: #212529;" />

        <!-- Campo de Texto: Contraseña -->
        <PasswordField fx:id="regPassword" prefHeight="40.0" promptText="Contraseña"
                       style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 14px; -fx-text-fill: #212529;" />

        <!-- Botón Principal de Registro -->
        <Button fx:id="regButton" mnemonicParsing="false" onAction="#handleReg" prefHeight="42.0" prefWidth="Infinity" text="Registrarse"
                style="-fx-background-color: #8E24AA; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
            <VBox.margin>
                <Insets top="5.0" />
            </VBox.margin>
        </Button>

        <!-- Enlace secundario para volver al Login -->
        <Button mnemonicParsing="false" onAction="#switchToView2" text="¿Ya tienes cuenta? Inicia sesión"
                style="-fx-background-color: transparent; -fx-text-fill: #8E24AA; -fx-font-size: 13px; -fx-cursor: hand;" />
    </children>
</VBox>
