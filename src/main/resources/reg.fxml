<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<VBox alignment="CENTER" prefHeight="400.0" prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com" xmlns:fx="http://fxml.com"
      fx:controller="com.example.demo.Controllers.RegLoginAuthController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="User Registration">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Label text="Registration" fx:id="regLable">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <TextField fx:id="regUsername" promptText="Username" />
        <TextField fx:id="regEmail" promptText="Email Address" />
        <PasswordField fx:id="regPassword" promptText="Password" />
        <Button fx:id="regButton" mnemonicParsing="false" onAction="#handleReg" prefWidth="150.0" text="Register" />
        <Button mnemonicParsing="false" onAction="#switchToView2" style="-fx-background-color: transparent; -fx-text-fill: #0066cc;" text="Already have an account? Log in" />
    </children>
</VBox>
