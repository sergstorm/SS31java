<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo.Controllers.TaskController"
            prefHeight="800"
            prefWidth="1200">

    <HBox prefHeight="800.0"
          prefWidth="1200.0"
          style="-fx-background-color: #F5F7FA;">
        <children>

            <!-- LEFT SIDEBAR: PROFILE CARD CONTAINER (Width: 350px) -->
            <VBox prefHeight="800.0" prefWidth="350.0" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 5, 0);">
                <children>
                    <!-- Header Banner Graphic Area -->
                    <VBox alignment="CENTER" prefHeight="220.0" prefWidth="350.0" style="-fx-background-color: #094BFF;">
                        <children>
                            <!-- Circular Avatar Base -->
                            <VBox alignment="CENTER" prefHeight="110.0" prefWidth="110.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 1000;">
                                <children>
                                    <Label text="👤" textFill="#094BFF">
                                        <font>
                                            <Font size="52.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <!-- Worker Details (Datos Section) -->
                    <VBox alignment="TOP_CENTER" spacing="15.0" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="30.0" left="25.0" right="25.0" top="25.0" />
                        </padding>
                        <children>
                            <Label text="John Doe" textFill="#212121">
                                <font>
                                    <Font name="System Bold" size="26.0" />
                                </font>
                            </Label>

                            <Label style="-fx-background-color: #E8EFFF; -fx-background-radius: 15; -fx-padding: 4 15 4 15;" text="FIELD WORKER" textFill="#094BFF">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>

                            <!-- Metadata Details Grid -->
                            <VBox fx:id="panelDetalles" spacing="10.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-padding: 15;">
                                <children>
                                    <HBox alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="Id:" textFill="#757575" prefWidth="80.0" />
                                            <!-- El ID no se debe editar porque es la llave primaria -->
                                            <TextField fx:id="txtId" editable="false" prefWidth="150.0" style="-fx-background-color: #E2E8F0;" />
                                        </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="Name:" textFill="#757575" prefWidth="80.0" />
                                            <TextField fx:id="txtName" prefWidth="150.0" />
                                        </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="Priority:" textFill="#757575" prefWidth="80.0" />
                                            <TextField fx:id="txtPriority" prefWidth="150.0" />
                                        </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="Deadline:" textFill="#757575" prefWidth="80.0" />
                                            <TextField fx:id="txtDeadline" prefWidth="150.0" />
                                        </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                        <children>
                                            <Label text="Status:" textFill="#757575" prefWidth="80.0" />
                                            <!-- Un ComboBox es mejor para el estado para evitar errores de escritura -->
                                            <ComboBox fx:id="cmbStatus" prefWidth="150.0" />
                                        </children>
                                    </HBox>

                                    <!-- Botones de acción -->
                                    <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                                        <children>
                                            <Button text="Limpiar" onAction="#limpiarSeleccion" style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-background-radius: 6;" />
                                            <Button text="Guardar" onAction="#actualizarTarea" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" />
                                            <Button text="Eliminar" onAction="#eliminarTarea" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>



                            <Pane VBox.vgrow="ALWAYS" />

                            <!-- Action buttons -->
                            <Button fx:id="editTableButton" onAction="#editWorkesTable" prefHeight="40.0" prefWidth="300.0"
                                    style="-fx-background-color: transparent; -fx-border-color: #BDBDBD; -fx-border-radius: 6; -fx-text-fill: #757575; -fx-font-weight: bold;"
                                    text="Agregar Nueva" />
                            <Button fx:id="backButton" onAction="#logout" prefHeight="40.0" prefWidth="300.0"
                                    style="-fx-background-color: transparent; -fx-border-color: #BDBDBD; -fx-border-radius: 6; -fx-text-fill: #757575; -fx-font-weight: bold;"
                                    text="Logout" />
                            <Button fx:id="backButton2" onAction="#goBackToLandingPage" prefHeight="40.0" prefWidth="300.0"
                                    style="-fx-background-color: transparent; -fx-border-color: #BDBDBD; -fx-border-radius: 6; -fx-text-fill: #757575; -fx-font-weight: bold;"
                                    text="BACK TO DASHBOARD" />
                        </children>
                    </VBox>
                </children>
            </VBox>

            <!-- RIGHT CONTENT AREA: TASKS TABLE & WORKER STATS (Width: 850px) -->
            <VBox prefHeight="800.0" prefWidth="850.0" spacing="25.0" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="30.0" left="35.0" right="35.0" top="35.0" />
                </padding>
                <children>

                    <!-- TOP VIEW TITLE -->
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <VBox>
                                <children>
                                    <Label text="Worker Performance &amp; Tasks Overview" textFill="#1A1D20">
                                        <font>
                                            <Font name="System Bold" size="28.0" />
                                        </font>
                                    </Label>
                                    <Label text="Monitor active workloads, operational delivery parameters, and logs." textFill="#8A92A6" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- COUNTER STATS CARDS ROW -->
                    <HBox spacing="20.0" prefHeight="100.0">
                        <children>
                            <!-- Stat Card 1 -->
                            <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                                <children>
                                    <Label text="Total Assigned Tasks" textFill="#8A92A6" style="-fx-font-size: 13;" />
                                    <Label fx:id="tat" text="42" textFill="#212121">
                                        <font>
                                            <Font name="System Bold" size="28.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                            <!-- Stat Card 2 -->
                            <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                                <children>
                                    <Label  text="In Progress" textFill="#8A92A6" style="-fx-font-size: 13;" />
                                    <Label fx:id="ipt" text="5" textFill="#094BFF">
                                        <font>
                                            <Font name="System Bold" size="28.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                            <!-- Stat Card 3 -->
                            <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                                <children>
                                    <Label  text="Completed Items" textFill="#8A92A6" style="-fx-font-size: 13;" />
                                    <Label fx:id="ct" text="37" textFill="#00AB33">
                                        <font>
                                            <Font name="System Bold" size="28.0" />
                                        </font>
                                    </Label>
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- DATALIST / TABLE CONTAINER -->
                    <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 8, 0, 0, 4);">
                        <children>
                            <Label text="Task Assignment Directory" textFill="#212121">
                                <font>
                                    <Font name="System Bold" size="16.0" />
                                </font>
                            </Label>

                            <!-- Main TableView Component -->
                            <TableView fx:id="tasksTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                                <columns>
                                    <TableColumn fx:id="TaskId" prefWidth="90.0" text="Task ID" />
                                    <TableColumn fx:id="speciality" prefWidth="280.0" text="Description" />
                                    <TableColumn fx:id="Experience" prefWidth="120.0" text="Priority" />
                                    <TableColumn fx:id="categoria" prefWidth="140.0" text="Time" />
                                    <TableColumn fx:id="achivment" prefWidth="130.0" text="Status" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </children>
                    </VBox>

                </children>
            </VBox>

        </children>
    </HBox>

</AnchorPane>
